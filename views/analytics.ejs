<!DOCTYPE html>
<html>
<head>
  <title>Analytics - LoanMatch</title>
  <style>
    body { font-family: sans-serif; margin: 40px; }
    nav a { margin-right: 15px; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; font-size: 14px; }
    th { background: #eee; }
    .tabs a { margin-right: 10px; padding: 5px 10px; text-decoration: none; border: 1px solid #ccc; }
    .tabs a.active { background: #333; color: #fff; }
  </style>
</head>
<body>
  <h1>Analytics</h1>
  <nav>
    <a href="/">Home</a>
    <a href="/users">Users</a>
    <a href="/loans">Loans</a>
    <a href="/banks">Banks</a>
    <a href="/analytics">Analytics</a>
  </nav>
  <hr>

  <div class="tabs" style="margin: 15px 0;">
    <a href="/analytics?query=1" class="<%= activeQuery === '1' ? 'active' : '' %>">Banks by State</a>
    <a href="/analytics?query=2" class="<%= activeQuery === '2' ? 'active' : '' %>">High-Value Loans</a>
    <a href="/analytics?query=3" class="<%= activeQuery === '3' ? 'active' : '' %>">Credit-Focused Banks</a>
  </div>

  <% if (activeQuery === '1') { %>
    <p>Bank count, avg income, and avg credit score per state.</p>
  <% } else if (activeQuery === '2') { %>
    <p>Loan purposes where amounts exceed the overall average.</p>
  <% } else { %>
    <p>Banks in areas with above-average credit scores.</p>
  <% } %>

  <table>
    <tr>
      <% if (results.length > 0) { %>
        <% Object.keys(results[0]).forEach(k => { %>
          <th><%= k.replace(/_/g, ' ') %></th>
        <% }); %>
      <% } %>
    </tr>
    <% results.forEach(row => { %>
    <tr>
      <% Object.values(row).forEach(v => { %>
        <td><%= v === null ? 'N/A' : (typeof v === 'number' && v % 1 !== 0 ? v.toFixed(2) : v) %></td>
      <% }); %>
    </tr>
    <% }); %>
  </table>
  <p><%= results.length %> results</p>
</body>
</html>
