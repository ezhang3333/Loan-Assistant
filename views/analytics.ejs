<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics - Loan Match</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #2563EB; --primary-hover: #1D4ED8; --primary-light: #DBEAFE;
      --accent: #8B5CF6; --accent-light: #EDE9FE;
      --surface: #FFFFFF; --surface-secondary: #F8FAFC;
      --text-primary: #0F172A; --text-secondary: #475569; --text-muted: #94A3B8;
      --border: #E2E8F0;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
      --radius-md: 8px; --radius-lg: 12px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--surface-secondary); color: var(--text-primary); -webkit-font-smoothing: antialiased; }
    .navbar { background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); padding: 0 32px; height: 64px; display: flex; align-items: center; gap: 32px; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
    .navbar .brand { font-size: 20px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: -0.5px; }
    .nav-links { display: flex; gap: 4px; margin-left: auto; }
    .nav-links a { color: var(--text-secondary); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 16px; border-radius: var(--radius-md); transition: all 200ms ease; }
    .nav-links a:hover { color: var(--primary); background: var(--primary-light); }
    .nav-links a.active { color: var(--primary); background: var(--primary-light); }
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 24px; }
    .page-header { margin-bottom: 32px; }
    .page-header h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; }
    .page-header p { color: var(--text-secondary); font-size: 15px; margin-top: 4px; }
    .section { background: var(--surface); border-radius: var(--radius-lg); padding: 24px; margin-bottom: 24px; box-shadow: var(--shadow-sm); border: 1px solid var(--border); }
    .section-title { font-size: 16px; font-weight: 600; margin-bottom: 16px; letter-spacing: -0.3px; }

    .query-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
    .query-tab {
      padding: 10px 20px;
      border: 1px solid var(--border);
      border-radius: 100px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      font-family: inherit;
      background: var(--surface);
      color: var(--text-secondary);
      text-decoration: none;
      transition: all 200ms ease;
    }
    .query-tab:hover { border-color: var(--primary); color: var(--primary); }
    .query-tab.active {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
      box-shadow: var(--shadow-md);
    }

    .query-desc {
      color: var(--text-secondary);
      font-size: 14px;
      margin-bottom: 20px;
      padding: 12px 16px;
      background: var(--accent-light);
      border-radius: var(--radius-md);
      border-left: 3px solid var(--accent);
    }

    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    th { padding: 12px; text-align: left; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; background: var(--surface-secondary); border-bottom: 1px solid var(--border); }
    td { padding: 12px; border-bottom: 1px solid #F1F5F9; color: var(--text-secondary); }
    tr:hover td { background: var(--surface-secondary); }
    td:first-child { font-weight: 600; color: var(--text-primary); }
    .table-wrapper { overflow-x: auto; border-radius: var(--radius-md); }
    .table-footer { padding: 12px 0 0; font-size: 13px; color: var(--text-muted); }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/" class="brand">LoanMatch</a>
    <div class="nav-links">
      <a href="/users">Users</a>
      <a href="/loans">Loans</a>
      <a href="/banks">Banks</a>
      <a href="/analytics" class="active">Analytics</a>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Analytics</h1>
      <p>Run advanced queries to uncover insights across banks, loans, and regions.</p>
    </div>

    <div class="section">
      <div class="section-title">Advanced Queries</div>

      <div class="query-tabs">
        <a href="/analytics?query=1" class="query-tab <%= activeQuery === '1' ? 'active' : '' %>">
          Banks by State
        </a>
        <a href="/analytics?query=2" class="query-tab <%= activeQuery === '2' ? 'active' : '' %>">
          High-Value Loans
        </a>
        <a href="/analytics?query=3" class="query-tab <%= activeQuery === '3' ? 'active' : '' %>">
          Credit-Focused Banks
        </a>
      </div>

      <% if (activeQuery === '1') { %>
        <div class="query-desc">Number of banks, average household income, and average credit score per state — sorted by bank count.</div>
      <% } else if (activeQuery === '2') { %>
        <div class="query-desc">Loan purposes where individual amounts exceed the overall average — grouped by purpose and sorted by average amount.</div>
      <% } else { %>
        <div class="query-desc">Banks located in areas with above-average credit scores — ranked by credit score descending.</div>
      <% } %>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <% if (results.length > 0) { %>
                <% Object.keys(results[0]).forEach(key => { %>
                  <th><%= key.replace(/_/g, ' ') %></th>
                <% }); %>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% results.forEach(row => { %>
            <tr>
              <% Object.values(row).forEach((val, i) => { %>
                <td>
                  <% if (val === null) { %>
                    N/A
                  <% } else if (typeof val === 'number' && val > 1000) { %>
                    <%= Number(val).toLocaleString(undefined, {maximumFractionDigits: 2}) %>
                  <% } else if (typeof val === 'number' && val % 1 !== 0) { %>
                    <%= Number(val).toFixed(2) %>
                  <% } else { %>
                    <%= val %>
                  <% } %>
                </td>
              <% }); %>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="table-footer"><%= results.length %> results</div>
    </div>
  </div>
</body>
</html>
