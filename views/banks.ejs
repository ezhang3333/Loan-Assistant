<!DOCTYPE html>
<html>
<head>
  <title>Banks - LoanMatch</title>
  <style>
    body { font-family: sans-serif; margin: 40px; }
    nav a { margin-right: 15px; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; font-size: 14px; }
    th { background: #eee; }
    input { padding: 4px; }
    fieldset { margin: 15px 0; padding: 15px; }
  </style>
</head>
<body>
  <h1>Banks</h1>
  <nav>
    <a href="/">Home</a>
    <a href="/users">Users</a>
    <a href="/loans">Loans</a>
    <a href="/banks">Banks</a>
    <a href="/analytics">Analytics</a>
  </nav>
  <hr>

  <fieldset>
    <legend>Filter by State</legend>
    <form action="/banks" method="GET">
      <label>State (2-letter)</label> <input type="text" name="state" maxlength="2" style="width:60px;">
      <button type="submit">Search</button>
      <a href="/banks">Reset</a>
    </form>
  </fieldset>

  <h3>Bank Directory (<%= banks.length %>)</h3>
  <table>
    <tr>
      <th>ID</th><th>Name</th><th>Type</th><th>Zipcode</th>
      <th>State</th><th>Median Income</th><th>Avg Credit Score</th>
    </tr>
    <% banks.forEach(b => { %>
    <tr>
      <td><%= b.bank_id %></td>
      <td><%= b.name %></td>
      <td><%= b.type %></td>
      <td><%= b.zipcode %></td>
      <td><%= b.state %></td>
      <td><%= b.medium_house_income || 'N/A' %></td>
      <td><%= b.avg_credit_score || 'N/A' %></td>
    </tr>
    <% }); %>
  </table>
</body>
</html>
