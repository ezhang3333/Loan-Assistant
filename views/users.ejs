<!DOCTYPE html>
<html>
<head>
  <title>Users - LoanMatch</title>
  <style>
    body { font-family: sans-serif; margin: 40px; }
    nav a { margin-right: 15px; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; font-size: 14px; }
    th { background: #eee; }
    input, select { padding: 4px; margin: 2px 0; }
    .msg-ok { color: green; }
    .msg-err { color: red; }
    fieldset { margin: 15px 0; padding: 15px; }
    label { display: inline-block; width: 140px; font-size: 14px; }
    .row { margin-bottom: 5px; }
  </style>
</head>
<body>
  <h1>Users</h1>
  <nav>
    <a href="/">Home</a>
    <a href="/users">Users</a>
    <a href="/loans">Loans</a>
    <a href="/banks">Banks</a>
    <a href="/analytics">Analytics</a>
  </nav>
  <hr>

  <% if (success) { %><p class="msg-ok"><%= success %></p><% } %>
  <% if (error) { %><p class="msg-err"><%= error %></p><% } %>

  <fieldset>
    <legend>Search</legend>
    <form action="/users/search" method="GET">
      <label>Username</label><input type="text" name="username">
      <label>Min Credit</label><input type="number" name="min_credit">
      <label>Max Credit</label><input type="number" name="max_credit">
      <button type="submit">Search</button>
      <a href="/users">Reset</a>
    </form>
  </fieldset>

  <fieldset>
    <legend>Add User</legend>
    <form action="/users/add" method="POST">
      <div class="row"><label>Username</label><input type="text" name="username" required></div>
      <div class="row"><label>Password</label><input type="password" name="password" required></div>
      <div class="row"><label>Gender</label>
        <select name="gender"><option>Male</option><option>Female</option><option>Other</option></select></div>
      <div class="row"><label>Marital Status</label>
        <select name="marital_status"><option>Single</option><option>Married</option><option>Divorced</option></select></div>
      <div class="row"><label>Annual Income</label><input type="number" name="annual_income" step="0.01"></div>
      <div class="row"><label>Credit Score</label><input type="number" name="credit_score"></div>
      <div class="row"><label>Loans Taken</label><input type="number" name="num_loans_taken" value="0"></div>
      <div class="row"><label>Age</label><input type="number" name="age"></div>
      <div class="row"><label>Employment</label>
        <select name="employment_status"><option>Employed</option><option>Self-employed</option><option>Unemployed</option><option>Student</option></select></div>
      <div class="row"><label>Existing Loans</label><input type="number" name="num_existing_loans" value="0"></div>
      <div class="row"><label>Zipcode</label><input type="number" name="zipcode"></div>
      <div class="row"><label>Loan Amount</label><input type="number" name="loan_amount_asked" step="0.01"></div>
      <button type="submit">Add</button>
    </form>
  </fieldset>

  <h3>All Users (<%= users.length %>)</h3>
  <table>
    <tr>
      <th>ID</th><th>Username</th><th>Gender</th><th>Marital</th><th>Income</th>
      <th>Credit</th><th>Age</th><th>Employment</th><th>Zipcode</th><th>Loan Asked</th><th></th>
    </tr>
    <% users.forEach(u => { %>
    <tr>
      <td><%= u.user_id %></td>
      <td><%= u.username %></td>
      <td><%= u.gender %></td>
      <td><%= u.marital_status %></td>
      <td><%= u.annual_income %></td>
      <td><%= u.credit_score %></td>
      <td><%= u.age %></td>
      <td><%= u.employment_status %></td>
      <td><%= u.zipcode %></td>
      <td><%= u.loan_amount_asked %></td>
      <td>
        <form action="/users/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
          <input type="hidden" name="user_id" value="<%= u.user_id %>">
          <button type="submit">Delete</button>
        </form>
      </td>
    </tr>
    <% }); %>
  </table>

  <fieldset>
    <legend>Update User</legend>
    <form action="/users/update" method="POST">
      <div class="row"><label>User ID</label><input type="number" name="user_id" required></div>
      <div class="row"><label>Username</label><input type="text" name="username" required></div>
      <div class="row"><label>Gender</label>
        <select name="gender"><option>Male</option><option>Female</option><option>Other</option></select></div>
      <div class="row"><label>Marital Status</label>
        <select name="marital_status"><option>Single</option><option>Married</option><option>Divorced</option></select></div>
      <div class="row"><label>Annual Income</label><input type="number" name="annual_income" step="0.01"></div>
      <div class="row"><label>Credit Score</label><input type="number" name="credit_score"></div>
      <div class="row"><label>Loans Taken</label><input type="number" name="num_loans_taken"></div>
      <div class="row"><label>Age</label><input type="number" name="age"></div>
      <div class="row"><label>Employment</label>
        <select name="employment_status"><option>Employed</option><option>Self-employed</option><option>Unemployed</option><option>Student</option></select></div>
      <div class="row"><label>Existing Loans</label><input type="number" name="num_existing_loans"></div>
      <div class="row"><label>Zipcode</label><input type="number" name="zipcode"></div>
      <div class="row"><label>Loan Amount</label><input type="number" name="loan_amount_asked" step="0.01"></div>
      <button type="submit">Update</button>
    </form>
  </fieldset>
</body>
</html>
